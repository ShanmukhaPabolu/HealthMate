# HealthMate Server Environment Configuration

# Server Port
PORT=5000

# MongoDB URI and Database Name
MONGO_URI=mongodb://127.0.0.1:27017/
DB_NAME=fitness

# JWT Secret Keys
JWT_SECRET=jwt_healthmate_secret_xyz
JWT_REFRESH_SECRET=jwt_healthmate_refresh_secret_abc
JWT_EXPIRES_IN=7d

# Gmail SMTP Server Credentials (OTP mailer)
# Note: Use port 465 (secure SSL) on hosting platforms like Render where port 587 is blocked
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=465
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password

# Cloudinary Storage Configurations (Badges/Reports upload)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# AI Search Service Key
IASK_API_KEY=your_iask_api_key
